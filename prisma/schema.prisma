// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
}

// NOTE: When using mysql or sqlserver, uncomment the //@db.Text annotations in model Account below
// Further reading:
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String //@db.Text
  email         String
  emailVerified Boolean   @default(false)
  isOnboarded   Boolean   @default(false)
  image         String? //@db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions        Session[]
  accounts        Account[]
  chatSessions    ChatSession[]
  scoringProfiles ScoringProfile[]
  workflows       Workflow[]
  workflowRuns    WorkflowRun[]

  @@unique([email])
  @@map("user")
}

model Opportunity {
  id                 String    @id @default(cuid())
  noticeId           String    @unique
  title              String
  solicitationNumber String?
  department         String
  subTier            String?
  office             String?
  type               String
  baseType           String?
  postedDate         DateTime
  responseDeadline   DateTime?
  naicsCode          String?
  classificationCode String?
  active             Boolean   @default(true)
  state              String?
  contactName        String?
  contactEmail       String?
  awardAmount        Float?
  awardeeName        String?
  rawJson            Json
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  chunks        OpportunityChunk[]
  scores        OpportunityScore[]
  captureBriefs CaptureBrief[]
}

model OpportunityChunk {
  id            String      @id @default(cuid())
  opportunityId String
  content       String
  embedding     Unsupported("vector(1024)")?
  metadata      Json?
  createdAt     DateTime    @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model ScoringProfile {
  id                String   @id @default(cuid())
  name              String
  isActive          Boolean  @default(true)
  targetNaics       Json     // string[]
  targetDepartments Json     // string[]
  preferredSetAsides Json    // string[]
  keywords          Json     // string[]
  minContractValue   Float?
  pursueThreshold    Int      @default(70)  // fitScore >= this → "pursue"
  watchThreshold     Int      @default(40)  // fitScore >= this → "watch", below → "skip"
  userId             String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores            OpportunityScore[]
  captureBriefs     CaptureBrief[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OpportunityScore {
  id             String   @id @default(cuid())
  opportunityId  String
  fitScore       Int      // 0-100
  recommendation String   // "pursue" | "watch" | "skip"
  rationale      String
  keyStrengths   Json     // string[]
  risks          Json     // string[]
  criteriaScores Json?    // Weighted sub-scores breakdown
  profileId      String
  scoredAt       DateTime @default(now())

  opportunity Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  profile     ScoringProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, profileId])
}

model CaptureBrief {
  id              String   @id @default(cuid())
  opportunityId   String
  profileId       String
  summary         String
  keyRequirements Json     // string[]
  competitiveEdge String
  suggestedTeam   Json     // string[]
  timeline        String
  generatedAt     DateTime @default(now())

  opportunity Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  profile     ScoringProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, profileId])
}

model WorkflowRun {
  id                     String    @id @default(cuid())
  type                   String    // "scoring" | "capture_brief" | "full_pipeline"
  status                 String    // "running" | "completed" | "failed"
  opportunitiesProcessed Int       @default(0)
  results                Json      // { scored, pursue, watch, skip, briefsGenerated }
  errors                 Json?
  userId                 String?
  user                   User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt              DateTime  @default(now())
  completedAt            DateTime?
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  nodes       Json     // ReactFlow Node[]
  edges       Json     // ReactFlow Edge[]
  isActive    Boolean  @default(false)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}
